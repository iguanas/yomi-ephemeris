# Dart / build
.dart_tool/
.packages
build/
.dart_tool

# Generated code. Vendored under lib/ so the package is consumable as a git
# dependency — consumers can't run build_runner on a pub-cache dependency.
# Anything generated outside lib/ (tests) stays ignored; CI regenerates it.
*.g.dart
*.freezed.dart
!lib/**/*.g.dart
!lib/**/*.freezed.dart

# Compiled server binary
bin/server
yomi-ephemeris-server

# Editor
.idea/
*.iml
.vscode/
